<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- coral-app is a webview wrapper. Needs network + JIT for WKWebView's
         JS engine. Does NOT need unsigned-memory or disable-library-validation
         (those are for PTY/process spawning in coral-tray only). -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Required: WKWebView uses JIT for JavaScript compilation -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
</dict>
</plist>
