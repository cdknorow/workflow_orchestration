<?xml version="1.0" encoding="UTF-8"?>

<!--
  WiX v4 installer definition for Coral.
  Builds an MSI that:
    - Installs coral.exe to Program Files\Coral
    - Adds Coral to the system PATH
    - Creates a Start Menu shortcut
    - Registers for clean uninstall
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="Coral"
    Manufacturer="Coral"
    Version="$(var.Version)"
    UpgradeCode="B8F2E3A1-7C4D-4E5F-9A1B-2C3D4E5F6A7B">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Coral is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Install to Program Files\Coral -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Coral">
        <Component Id="CoralExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <File Id="coral.exe" Source="$(var.BinDir)\coral.exe" KeyPath="yes" />

          <!-- Add to PATH -->
          <Environment
            Id="PATH"
            Name="PATH"
            Value="[INSTALLFOLDER]"
            Permanent="no"
            Part="last"
            Action="set"
            System="yes" />
        </Component>

        <Component Id="LaunchCoralExe" Guid="C3D4E5F6-A7B8-9012-CDEF-234567890123">
          <File Id="launch_coral.exe" Source="$(var.BinDir)\launch-coral.exe" KeyPath="yes" />
        </Component>

        <Component Id="CoralBoardExe" Guid="D4E5F6A7-B8C9-0123-DEFA-345678901234">
          <File Id="coral_board.exe" Source="$(var.BinDir)\coral-board.exe" KeyPath="yes" />
        </Component>

        <Component Id="CoralTrayExe" Guid="E5F6A7B8-C9D0-1234-EFAB-456789012345">
          <File Id="coral_tray.exe" Source="$(var.BinDir)\coral-tray.exe" KeyPath="yes" />
        </Component>

        <Component Id="CoralAppExe" Guid="F6A7B8C9-D0E1-2345-FABC-567890123456">
          <File Id="coral_app.exe" Source="$(var.BinDir)\coral-app.exe" KeyPath="yes" />
        </Component>

        <Component Id="HookAgenticState" Guid="A7B8C9D0-E1F2-3456-ABCD-678901234567">
          <File Id="coral_hook_agentic_state.exe" Source="$(var.BinDir)\coral-hook-agentic-state.exe" KeyPath="yes" />
        </Component>

        <Component Id="HookTaskSync" Guid="B8C9D0E1-F2A3-4567-BCDE-789012345678">
          <File Id="coral_hook_task_sync.exe" Source="$(var.BinDir)\coral-hook-task-sync.exe" KeyPath="yes" />
        </Component>

        <Component Id="HookMessageCheck" Guid="C9D0E1F2-A3B4-5678-CDEF-890123456789">
          <File Id="coral_hook_message_check.exe" Source="$(var.BinDir)\coral-hook-message-check.exe" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="CoralMenuFolder" Name="Coral">
        <Component Id="CoralShortcut" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
          <Shortcut
            Id="CoralStartMenuShortcut"
            Name="Coral"
            Target="[INSTALLFOLDER]coral-tray.exe"
            Arguments="--backend pty"
            WorkingDirectory="INSTALLFOLDER"
            Description="Coral — AI Agent Dashboard" />

          <RemoveFolder Id="RemoveCoralMenuFolder" On="uninstall" />
          <RegistryValue
            Root="HKCU"
            Key="Software\Coral"
            Name="installed"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Coral" Level="1">
      <ComponentRef Id="CoralExe" />
      <ComponentRef Id="LaunchCoralExe" />
      <ComponentRef Id="CoralBoardExe" />
      <ComponentRef Id="CoralTrayExe" />
      <ComponentRef Id="CoralAppExe" />
      <ComponentRef Id="HookAgenticState" />
      <ComponentRef Id="HookTaskSync" />
      <ComponentRef Id="HookMessageCheck" />
      <ComponentRef Id="CoralShortcut" />
    </Feature>

  </Package>

</Wix>
