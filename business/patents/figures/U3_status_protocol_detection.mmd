%% FIGURE U3 — Inline Status Protocol Detection Flowchart
%% Patent: System and Method for Multi-Agent AI Orchestration
%% Method flow for Claim 2 — Real-Time Agent Status Extraction

flowchart TD
    START([START:<br/>Scan cycle triggered])
    --> READ_POS["Retrieve stored read<br/>position for agent's<br/>log stream"]
    --> CHECK_SIZE{"New content<br/>appended?<br/>(stream size &gt;<br/>read position)"}

    CHECK_SIZE -->|No| CHECK_TRUNC{"Stream size &lt;<br/>read position?<br/>(truncation detected)"}
    CHECK_TRUNC -->|Yes| RESET_POS["Reset read position<br/>to beginning<br/>(handle agent restart)"]
    RESET_POS --> SEEK
    CHECK_TRUNC -->|No| IDLE_CHECK

    CHECK_SIZE -->|Yes| SEEK["Seek to stored<br/>read position"]
    --> READ_NEW["Read newly appended<br/>content from<br/>log stream"]
    --> STRIP["Strip terminal<br/>escape sequences<br/>to obtain clean text"]
    --> MATCH{"Pattern match:<br/>structured event<br/>markers found?"}

    MATCH -->|No| UPDATE_POS["Update stored<br/>read position to<br/>current stream end"]
    --> IDLE_CHECK

    MATCH -->|Yes| EXTRACT["Extract event type<br/>and payload from<br/>each matched marker"]
    --> FILTER{"False positive?<br/>(instruction echo<br/>or placeholder)"}

    FILTER -->|Yes, discard| NEXT_MATCH{"More<br/>matches?"}
    FILTER -->|No, valid event| EVENT_TYPE{"Event type?"}

    EVENT_TYPE -->|STATUS| DEDUP_S{"Payload changed<br/>from last known<br/>STATUS value?"}
    DEDUP_S -->|Yes| BROADCAST_S["Update real-time<br/>status indicator<br/>in dashboard"]
    --> STORE
    DEDUP_S -->|No, unchanged| NEXT_MATCH

    EVENT_TYPE -->|SUMMARY| DEDUP_G{"Payload changed<br/>from last known<br/>SUMMARY value?"}
    DEDUP_G -->|Yes| BROADCAST_G["Update goal<br/>indicator in<br/>dashboard"]
    --> STORE
    DEDUP_G -->|No, unchanged| NEXT_MATCH

    EVENT_TYPE -->|CONFIDENCE| BROADCAST_C["Update confidence<br/>indicator with<br/>level and reason"]
    --> STORE

    STORE["Persist event to<br/>data store with<br/>timestamp and<br/>session identifier"]
    --> PUSH["Broadcast to connected<br/>dashboard clients via<br/>push-based connection"]
    --> NEXT_MATCH

    NEXT_MATCH -->|Yes| EXTRACT
    NEXT_MATCH -->|No| UPDATE_POS

    IDLE_CHECK{"Agent idle?<br/>(log modification time<br/>exceeds configurable<br/>threshold AND last event<br/>= waiting state)"}
    -->|Yes| IS_SLEEPING{"Agent<br/>suspended?"}
    IS_SLEEPING -->|Yes, skip| DONE
    IS_SLEEPING -->|No| ALREADY_NOTIFIED{"Already notified<br/>for this idle<br/>period?"}
    ALREADY_NOTIFIED -->|Yes| DONE
    ALREADY_NOTIFIED -->|No| WEBHOOK["Create notification<br/>delivery record and<br/>dispatch to configured<br/>external endpoints"]
    --> TRACK["Record in tracking set<br/>(prevents duplicate alerts<br/>until agent resumes)"]
    --> DONE

    IDLE_CHECK -->|No| DONE([END:<br/>Scan cycle complete])

    %% Styling
    classDef startEnd fill:#2B4C7E,stroke:#1A365D,color:#FFFFFF,stroke-width:2px
    classDef process fill:#3D6098,stroke:#2B4C7E,color:#FFFFFF,stroke-width:1px
    classDef decision fill:#8B6914,stroke:#6B4F10,color:#FFFFFF,stroke-width:2px
    classDef broadcast fill:#4A7C59,stroke:#2D5A3D,color:#FFFFFF,stroke-width:1px
    classDef alert fill:#8B3A3A,stroke:#6B2020,color:#FFFFFF,stroke-width:2px

    class START,DONE startEnd
    class READ_POS,SEEK,READ_NEW,STRIP,EXTRACT,STORE,PUSH,UPDATE_POS,RESET_POS,TRACK process
    class CHECK_SIZE,CHECK_TRUNC,MATCH,FILTER,EVENT_TYPE,DEDUP_S,DEDUP_G,NEXT_MATCH,IDLE_CHECK,IS_SLEEPING,ALREADY_NOTIFIED decision
    class BROADCAST_S,BROADCAST_G,BROADCAST_C broadcast
    class WEBHOOK alert
