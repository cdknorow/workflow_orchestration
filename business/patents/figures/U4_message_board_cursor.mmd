%% FIGURE U4 — Message Board Cursor Mechanism Flowchart
%% Patent: System and Method for Multi-Agent AI Orchestration
%% Method flow for Claim 3 — Cursor-Based Inter-Agent Communication
%% Shows both Read and Post operations

flowchart TD
    subgraph READ["READ OPERATION"]
        direction TB
        R_START([Agent issues<br/>read request])
        --> R_RETRIEVE["Retrieve agent's<br/>independent read cursor<br/>(last_read_id) from<br/>subscriber record"]
        --> R_QUERY["Query message board:<br/>all messages with<br/>ID &gt; last_read_id<br/>WHERE sender ≠<br/>requesting agent"]
        --> R_RESULTS{"Messages<br/>found?"}

        R_RESULTS -->|Yes| R_COMPUTE["Compute new cursor:<br/>MAX(<br/>&nbsp;&nbsp;current cursor,<br/>&nbsp;&nbsp;highest delivered message ID,<br/>&nbsp;&nbsp;agent's own highest posted ID<br/>)<br/><br/><i>Own posts don't block<br/>cursor progression</i>"]
        --> R_UPDATE["Update subscriber record<br/>with new cursor value"]
        --> R_RETURN["Return messages<br/>to requesting agent"]
        --> R_END([Read complete:<br/>exactly-once delivery<br/>guaranteed])

        R_RESULTS -->|No| R_COMPUTE_EMPTY["Compute new cursor:<br/>(still advances past<br/>agent's own posts)"]
        --> R_UPDATE_EMPTY["Update subscriber record"]
        --> R_RETURN_EMPTY["Return empty<br/>result set"]
        --> R_END
    end

    subgraph POST["POST OPERATION"]
        direction TB
        P_START([Agent issues<br/>post request])
        --> P_APPEND["Append new message<br/>to ordered sequence<br/>with next sequential<br/>monotonic integer ID"]
        --> P_RECORD["Record sender ID,<br/>timestamp, and<br/>content payload"]
        --> P_NO_CURSOR["No cursor advancement<br/>for any subscriber<br/><br/><i>Cursors advance<br/>only on read</i>"]
        --> P_CONFIRM["Return confirmation<br/>to posting agent"]
        --> P_END([Post complete:<br/>message available for<br/>all other subscribers<br/>on their next read])
    end

    subgraph GUARANTEES["DELIVERY GUARANTEES"]
        direction TB
        G1["<b>Exactly-once delivery</b><br/>Each message delivered<br/>to each subscriber<br/>at most once"]
        G2["<b>No message loss</b><br/>Messages accumulate<br/>while agent is offline;<br/>delivered on next read"]
        G3["<b>Independent pacing</b><br/>Each subscriber reads<br/>at its own rate"]
        G4["<b>Self-message filtering</b><br/>Agents never receive<br/>their own posts"]
        G5["<b>Restart resilience</b><br/>Cursor persisted in<br/>data store; survives<br/>process restarts"]
    end

    %% Styling
    classDef startEnd fill:#2B4C7E,stroke:#1A365D,color:#FFFFFF,stroke-width:2px
    classDef process fill:#3D6098,stroke:#2B4C7E,color:#FFFFFF,stroke-width:1px
    classDef decision fill:#8B6914,stroke:#6B4F10,color:#FFFFFF,stroke-width:2px
    classDef guarantee fill:#4A7C59,stroke:#2D5A3D,color:#FFFFFF,stroke-width:1px
    classDef nocursor fill:#8B3A3A,stroke:#6B2020,color:#FFFFFF,stroke-width:1px

    class R_START,R_END,P_START,P_END startEnd
    class R_RETRIEVE,R_QUERY,R_COMPUTE,R_UPDATE,R_RETURN,R_COMPUTE_EMPTY,R_UPDATE_EMPTY,R_RETURN_EMPTY process
    class P_APPEND,P_RECORD,P_CONFIRM process
    class R_RESULTS decision
    class G1,G2,G3,G4,G5 guarantee
    class P_NO_CURSOR nocursor
